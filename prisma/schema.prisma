generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Director {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  movies Movie[]
}

model Movie {
  id          Int    @id @default(autoincrement())
  title       String
  description String?
  releaseYear Int
  genre       String
  directorId  Int

  director Director @relation(fields: [directorId], references: [id])
}